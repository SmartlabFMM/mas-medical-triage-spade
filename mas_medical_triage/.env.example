# XMPP / SPADE Configuration
XMPP_SERVER=localhost

# Agent JIDs (Jabber IDs)
JID_CONVERSATIONAL=conversational@localhost
JID_CLINICAL=clinical@localhost
JID_RESOURCE=resource@localhost
JID_META=meta@localhost

# Agent Passwords - CHANGE THESE IN PRODUCTION!
PWD_CONVERSATIONAL=conv123
PWD_CLINICAL=clin123
PWD_RESOURCE=res123
PWD_META=meta123

# Hospital Configuration
HOSPITAL_NAME=Urgences_Demo
BEDS_TOTAL=20
BEDS_AVAILABLE=15
WAIT_TIME_AVG=12.5

# Medical Specialists
SPECIALIST_CARDIO=2
SPECIALIST_NEURO=1
SPECIALIST_TRAUMA=3
SPECIALIST_GENERAL=5

# Simulation Settings
MAX_PATIENTS=20
TRIAGE_TIMEOUT=6
SIMULATION_SPEED=1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/triage.log

# Google Sheets Integration
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
GOOGLE_SPREADSHEET_NAME=MAS_Resources

# LLM Configuration
GROQ_API_KEY=

# Security Settings
XMPP_VERIFY_SECURITY=true
XMPP_ALLOW_TLS=true
XMPP_VERIFY_CERTIFICATE=false  # Set to true for production servers with valid certificates
